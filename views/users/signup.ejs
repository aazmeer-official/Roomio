<% layout('/layouts/boilerplate') -%>

<div class="row mt-3">
    <h1 class=" col-6 offset-3">SignUp for Roomio</h1>
    <div class="col-6 offset-3">
    <form action="/signup" method="post"  novalidate  class="needs-validation">
        <div class="mt-3">        
            <label for="username" class="form-label">Enter a Unique Username</label>
            <input type="text" name="username" id="username" placeholder="Add a username" class="form-control" required>
            <div class="valid-feedback">
                Looks good!
            </div>
            <div class="invalid-feedback">
                Please choose a valid Username.
            </div>
        </div>
        <div class="mt-3">        
            <label for="email" class="form-label">Write Email</label>
            <input type="email" name="email" id="email" placeholder="Add an Email" class="form-control" required>
            <div class="valid-feedback">
                Looks good!
            </div>
            <div class="invalid-feedback">
                Please write a valid Emial 
            </div>
        </div>
        <div class="mt-3">        
            <label for="password" class="form-label">Enter Password</label>
            <input type="password" name="password" id="password" placeholder="Add a Password" class="form-control" required>
            <div class="valid-feedback">
                Looks good!
            </div>
            <div class="invalid-feedback">
                Please write a valid Password
            </div>
        </div>

        <div class="mb-3 mt-3">
            <button type="submit" class="btn btn-dark add-btn">Submit</button>
        </div>
        </form>
    </div>
</div>